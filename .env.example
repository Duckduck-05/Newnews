# Copy thành .env (KHÔNG commit .env — đã có trong .gitignore) để chạy local.
# Xem README.md mục "Secrets cần thiết" để biết cách lấy từng key.

GEMINI_API_KEY=
DEEPSEEK_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PRODUCTHUNT_TOKEN=

# DRY_RUN=true -> in console, không gọi Telegram API thật.
DRY_RUN=true
